rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData(request.auth.uid).role == role;
    }

    function isManager() {
      return hasRole('manager');
    }

    function isExecutive() {
      return hasRole('executive');
    }

    function isWorker() {
      return hasRole('worker');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      // Executives can promote/demote or view all users (in reality, role changes should be server-side, but keeping it simple for now)
      allow write: if isExecutive();
    }

    // --- Production: Livestock ---
    match /production_livestock/{entryId} {
      allow read: if isManager() || isExecutive();
      allow create, update: if (isManager() || isWorker() || isExecutive()) && 
        request.resource.data.keys().hasAll(['date', 'cowId', 'milkVolume', 'feedConsumed']) &&
        request.resource.data.milkVolume is number &&
        request.resource.data.feedConsumed is number;
      allow delete: if isManager() || isExecutive();
    }

    // --- Production: Poultry ---
    match /production_poultry/{entryId} {
      allow read: if isManager() || isExecutive();
      allow create, update: if (isManager() || isWorker() || isExecutive()) && 
        request.resource.data.keys().hasAll(['date', 'eggCount', 'feedConsumed']) &&
        request.resource.data.eggCount is int &&
        request.resource.data.feedConsumed is number;
      allow delete: if isManager() || isExecutive();
    }

    // --- Crop Cycles ---
    match /crop_cycles/{cropId} {
      allow read: if isManager() || isExecutive() || isWorker();
      allow write: if isManager() || isExecutive();
    }

    // --- Sales ---
    match /sales/{saleId} {
      allow read: if isManager() || isExecutive();
      allow write: if isManager() || isExecutive();
    }

    // --- Expenses ---
    match /expenses/{expenseId} {
      allow read: if isManager() || isExecutive();
      allow create: if isManager() || isExecutive();
      allow update, delete: if isExecutive();
    }

    // --- Settings ---
    match /settings/global {
      allow read: if isSignedIn();
      allow write: if isExecutive() || isManager();
    }

    // --- Equipment ---
    match /equipment/{equipmentId} {
      allow read: if isManager() || isExecutive() || isWorker();
      allow write: if isManager() || isExecutive();

      match /service_history/{serviceId} {
        allow read: if isManager() || isExecutive() || isWorker();
        allow create: if isManager() || isWorker() || isExecutive();
        allow update, delete: if isManager() || isExecutive();
      }
    }

    // --- Tasks ---
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isManager() || isExecutive();
      allow update: if isManager() || isExecutive() || (isWorker() && request.auth.uid == resource.data.assignedToUid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
      allow delete: if isManager() || isExecutive();
    }
  }
}
